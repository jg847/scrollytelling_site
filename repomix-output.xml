      title: "Sample",
      language: "ts",
      code: "const depth = 200;",
    });
  });

  it("keeps ordinary colon-prefixed code as code", () => {
    expect(parseCodeSampleSource("status: ok\n\nnext line")).toEqual({
      code: "status: ok\n\nnext line",
