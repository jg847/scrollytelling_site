        style={{
          height: hasBackground ? "200vh" : "170vh",
          position: "relative",
          zIndex: index,
          backgroundColor,
        }}
      >
        <div style={{ position: "sticky", top: 0, height: "100vh" }}>
          {children}
        </div>
      </section>
    </SlideContext.Provider>
  );
}
